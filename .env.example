NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up 
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard 
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard 
NEXT_PUBLIC_LIVE_URL=localhost:3000
NEXT_PUBLIC_MARKETING_URL=https://robustagency.co

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Retell AI
RETELL_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Resend — used to email candidates their invite links.
# Get your API key at https://resend.com/api-keys.
# INVITE_EMAIL_FROM must be a verified address on a Resend-verified domain,
# e.g. "Robust Devs Hiring <invites@yourdomain.com>".
# Leaving these blank disables email send — the invite row is still
# created, and recruiters can copy the link manually.
RESEND_API_KEY=
INVITE_EMAIL_FROM=

# Hiring-grade analytics v2 (openspec change hiring-grade-analytics-scoring).
# Both default to false; rollout sequence is documented in the change's
# design.md (Decision 1):
#   1. Deploy code with both flags false → behaviour identical to today.
#   2. Apply migration.sql (adds interview JD columns + response.analytics_v1).
#   3. Set ANALYTICS_V2_ENABLED=true → webhook starts dual-writing v2 to
#      response.analytics_v1; dashboard still reads v1 from analytics.
#   4. Run scripts/calibrate-analytics.ts over ~7 days of dual-write data.
#      Spot-check diverse demographic samples for bias regressions.
#   5. Set ANALYTICS_V2_AS_PRIMARY=true → dashboard displays v2; v1 archived
#      to analytics_v1 column.
ANALYTICS_V2_ENABLED=false
ANALYTICS_V2_AS_PRIMARY=false
