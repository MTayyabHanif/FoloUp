NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up 
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard 
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard 
NEXT_PUBLIC_LIVE_URL=localhost:3000
NEXT_PUBLIC_MARKETING_URL=https://robustagency.co

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Retell AI
RETELL_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Resend — used to email candidates their invite links.
# Get your API key at https://resend.com/api-keys.
# INVITE_EMAIL_FROM must be a verified address on a Resend-verified domain,
# e.g. "Robust Devs Hiring <invites@yourdomain.com>".
# Leaving these blank disables email send — the invite row is still
# created, and recruiters can copy the link manually.
RESEND_API_KEY=
INVITE_EMAIL_FROM=

# Required by scripts/calibrate-analytics.ts and the proctoring server
# routes that look up response/interview rows server-side. Never expose
# in client bundles. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 — used by the add-interview-proctoring-camera-screen
# feature to store candidate camera + screen recordings. Chosen over
# Supabase Storage for zero egress fees and a 10 GB free tier.
# See supabase_schema.sql "PROCTORING BUCKET SETUP" block for setup steps.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=proctoring
